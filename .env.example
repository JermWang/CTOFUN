# ============================================================================
# CTO.fun environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ============================================================================

# --- Privy (auth + embedded Solana wallets) ---------------------------------
# Create an app at https://dashboard.privy.io and enable Solana embedded wallets.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Supabase ----------------------------------------------------------------
# From your project's API settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Solana / Helius ---------------------------------------------------------
# RPC endpoint used for on-chain reads and buyback execution.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=

# --- Native token (the coordination token) ----------------------------------
# Mint address of the CTO.fun token, once launched.
NEXT_PUBLIC_TOKEN_MINT=
# Optional server-only RPC override for target token-holder checks.
SOLANA_RPC_URL=

# --- Treasury automation ----------------------------------------------------
# Public treasury address that receives CTO.fun creator fees.
TREASURY_WALLET=
# Explicit kill switch for hot-wallet signing. Keep false until the server
# secret below is set in Vercel/hosting env.
TREASURY_SIGNER_ENABLED=false
# SERVER ONLY. Base58 Solana secret key, JSON secret-key array, or 32-byte seed.
# Never commit this, paste it into chat, or expose it with NEXT_PUBLIC_.
TREASURY_SIGNER_SECRET=
# PumpPortal Local collectCreatorFee priority fee in SOL.
PUMPFUN_CREATOR_FEE_PRIORITY_FEE_SOL=0.000001

# --- Next.js production hardening -------------------------------------------
# Required when self-hosting multiple instances so Server Action encryption is
# stable across replicas/builds. Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- Automatic dead-token sweeper -------------------------------------------
# Used by Vercel Cron / route handler auth. Generate with: openssl rand -base64 32
CRON_SECRET=
# Minimum age and dormancy gates for Pump.fun-origin candidates.
DEAD_TOKEN_MIN_AGE_DAYS=120
DEAD_TOKEN_MIN_DORMANT_DAYS=45
# Set false to skip DexScreener best-effort current liquidity/volume enrichment.
DEXSCREENER_ENRICHMENT=true
